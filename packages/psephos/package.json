        "prepublishOnly": "../../utils/package-pre-publish-check.sh"
    },
    "dependencies": {
        "@ethosengine/sophia-core": "workspace:*"
    },
    "devDependencies": {
        "perseus-build-settings": "workspace:*",
        "react": "catalog:devDeps",
        "react-dom": "catalog:devDeps"
    },
    "peerDependencies": {
        "react": "catalog:peerDeps",
        "react-dom": "catalog:peerDeps"
    },
    "keywords": [
        "governance",
