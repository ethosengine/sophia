{
    "name": "@ethosengine/psephos",
    "description": "Governance ballot rendering — the third Sophia pillar",
    "author": "Ethos Engine",
    "license": "UNLICENSED",
    "version": "0.1.0",
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/ethosengine/sophia.git",
        "directory": "packages/psephos"
    },
    "bugs": {
        "url": "https://github.com/ethosengine/sophia/issues"
    },
    "module": "dist/es/index.js",
